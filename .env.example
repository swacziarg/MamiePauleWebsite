# ==========================================================
# Variables publiques nécessaires au fonctionnement du site
# ==========================================================
#
# 1) NEXT_PUBLIC_SUPABASE_URL
#    URL du projet Supabase, visible dans Settings > API
#
# 2) NEXT_PUBLIC_SUPABASE_ANON_KEY
#    Clé "anon" publique Supabase, visible dans Settings > API
#
# 3) NEXT_PUBLIC_SITE_URL
#    URL publique du site utilisée pour :
#    - le bouton "Partager"
#    - le QR code
#    - les redirections du lien magique
#    En local : http://localhost:3000
#    En production : https://votre-domaine.fr

# URL publique de votre projet Supabase
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co

# Clé publique anonyme Supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_cle_anon_supabase

# URL publique du site pour le QR code, le partage et la redirection de connexion
NEXT_PUBLIC_SITE_URL=http://localhost:3000
